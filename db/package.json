{
  "name": "@bluecare/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema/index.ts",
    "./schema/*": "./schema/*.ts",
    "./client": "./client.ts",
    "./rls": "./rls/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "seed": "tsx ./seed/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@bluecare/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.46.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.1",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.29.1",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
