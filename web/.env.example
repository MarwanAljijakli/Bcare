# Copy to web/.env.local. See docs/deploy.md for the full env-var checklist.

# --- Public (exposed to the browser) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only ---
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- AI / quality vectors (Quality Fix override) ---
# Server-only. NEVER prefix with NEXT_PUBLIC_ — these never reach the browser.
# Wire via `vercel env add <NAME> <env> --value '<value>' --yes` for
# production + development; pass an empty positional git-branch arg for preview:
# `vercel env add <NAME> preview "" --value '<value>' --yes`.
#
# Costs are governed by aiGuard against AI_MONTHLY_BUDGET_USD_PER_CHILD.
# ANTHROPIC_API_KEY=               # Claude Sonnet 4.6 — vocab suggestions, symbol-image audit, sentence completion
# ELEVENLABS_API_KEY=              # ElevenLabs Multilingual v2 — TTS for both EN + AR
# OPENAI_API_KEY=                  # Whisper STT (whisper-1)

# --- Cost guard ---
# Quality Fix raised this from 5 → 20 to fund ElevenLabs + Claude + Whisper
# at expected per-child volume. Cache hit rate ≥ 60% keeps the line item low.
AI_MONTHLY_BUDGET_USD_PER_CHILD=20

# --- Observability ---
# SENTRY_DSN=
# POSTHOG_PROJECT_API_KEY=

# --- Cron ---
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`. The personalization,
# voice-prewarm, and weekly-report routes refuse non-matching requests.
CRON_SECRET=

# --- STT model override (optional) ---
# Phase 10.B defaults to `gpt-4o-mini-transcribe`. Set this to `whisper-1`
# to fall back to the legacy Whisper model if the new endpoint regresses.
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
